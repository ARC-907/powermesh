# PowerMesh — environment overrides
#
# Copy this file to ".env" and fill in values, then export them (or use direnv
# / dotenv / your service manager's EnvironmentFile= directive). The collector
# and agent read these at startup; empty values are ignored and the YAML
# defaults are kept.
#
# Names below match the keys declared in src/config.py (MESH_ENV / NODE_ENV).

# ───── Collector (mesh) ─────────────────────────────────────────────
# Bind address. Loopback by default — the collector REFUSES to start on a
# non-loopback bind unless --public is passed AND auth_tokens (in mesh.yaml)
# is non-empty. See SECURITY.md.
POWERMESH_HOST=127.0.0.1

# HTTP port for the collector.
POWERMESH_COLLECTOR_PORT=8430

# How many days of raw readings to keep before pruning.
POWERMESH_RETENTION_DAYS=30

# Default electricity rate (used when a node does not specify one).
POWERMESH_COST_PER_KWH=0.12

# ───── Agent (node) ─────────────────────────────────────────────────
# Stable identifier for this node (defaults to hostname if empty).
POWERMESH_NODE_ID=

# URL the agent posts readings to.
POWERMESH_COLLECTOR_URL=http://127.0.0.1:8430

# HMAC shared secret. Must match the value the collector has for this node_id
# (or for "*") in mesh.yaml's auth_tokens map.
POWERMESH_AUTH_TOKEN=

# How often the agent samples and pushes.
POWERMESH_COLLECTION_INTERVAL_S=60
POWERMESH_PUSH_BATCH_SIZE=10

# ───── Shared ───────────────────────────────────────────────────────
# Runtime data directory (SQLite db + logs).
POWERMESH_DATA_DIR=

# DEBUG / INFO / WARNING / ERROR
POWERMESH_LOG_LEVEL=INFO
